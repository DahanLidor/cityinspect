# CityInspect Backend Environment Variables
# Copy to .env and customize for your deployment

APP_NAME=CityInspect API
APP_VERSION=1.0.0
DEBUG=true

# Auth
SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=postgresql+asyncpg://cityinspect:cityinspect@db:5432/cityinspect

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads

# AI Service
AI_SERVICE_URL=http://ai-service:8001
AI_CONFIDENCE_THRESHOLD=0.45

# Duplicate Detection
DUPLICATE_GPS_RADIUS_M=25.0
DUPLICATE_IMAGE_THRESHOLD=0.85
DUPLICATE_LIDAR_THRESHOLD=0.80

# Redis
REDIS_URL=redis://redis:6379/0
